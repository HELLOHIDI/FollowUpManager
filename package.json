{
  "name": "template",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/assert-auth-env.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:project-storage": "powershell -ExecutionPolicy Bypass -File scripts/test-project-storage.ps1",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "env:check": "dotenv -e .env.local -- tsx scripts/check-env.ts",
    "check:ui-baseline": "node scripts/check-ui-baseline.mjs",
    "env:auth": "node scripts/assert-auth-env.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/react-query": "^5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "hono": "^4.9.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "next": "15.5.19",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7",
    "server-only": "0.0.1",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "happy-dom": "20.10.6",
    "postcss": "^8",
    "supabase": "2.107.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
